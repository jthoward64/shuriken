{
	"name": "shuriken",
	"version": "0.0.0",
	"exports": "./src/index.ts",
	"tasks": {
		"start": "deno run --allow-net --allow-env --allow-read --allow-sys --env-file=.env src/index.ts",
		"dev": "deno run --watch --allow-net --allow-env --allow-read --allow-sys --env-file=.env src/index.ts",
		"docker:start": "deno task migrations:run && deno task start",
		"test": "deno test --allow-net --allow-env --allow-read --allow-write --allow-sys --env-file=.env --no-check",
		"test:unit": "deno test --allow-net --allow-env --allow-read --allow-write --allow-sys --no-check 'src/**/*.unit.test.ts'",
		"test:integration": "deno test --allow-net --allow-env --allow-read --allow-write --allow-sys --env-file=.env --no-check 'src/**/*.integration.test.ts'",
		"check": "deno check src/",
		"lint": "deno run -A npm:@biomejs/biome@2.4.9 lint",
		"format": "deno run -A npm:@biomejs/biome@2.4.9 format",
		"fix": "deno run -A npm:@biomejs/biome@2.4.9 check --fix",
		"verify": "deno check src/ && deno run -A npm:@biomejs/biome@2.4.9 check",
		"migrations:gen": "deno run -A --env-file=.env drizzle-kit generate && rm src/testing/test-db-cache.tar.gz || true",
		"migrations:run": "deno run -A --env-file=.env drizzle-kit migrate",
		"db:reset": "deno run --allow-net --allow-env --allow-read --env-file=.env scripts/db-reset.ts && deno task migrations:run",
		"hooks": "git config core.hooksPath .husky",
		"studio": "deno run -A --env-file=.env drizzle-kit studio"
	},
	"imports": {
		"#src/": "./src/",
		"@electric-sql/pglite-icu-full": "npm:@electric-sql/pglite-icu-full@^0.1.0",
		"effect": "npm:effect@4.0.0-beta.88",
		"effect/": "npm:/effect@4.0.0-beta.88/",
		"@effect/platform-node": "npm:@effect/platform-node@4.0.0-beta.88",
		"@effect/sql-pg": "npm:@effect/sql-pg@4.0.0-beta.88",
		"@effect/sql-pglite": "npm:@effect/sql-pglite@4.0.0-beta.88",
		"casbin": "npm:casbin@^5.51.0",
		"drizzle-adapter": "npm:drizzle-adapter@^1.4.0",
		"drizzle-orm": "npm:drizzle-orm@1.0.0-rc.3",
		"drizzle-orm/": "npm:/drizzle-orm@1.0.0-rc.3/",
		"drizzle-kit": "npm:drizzle-kit@1.0.0-rc.3",
		"fast-xml-builder": "npm:fast-xml-builder@^1.2.0",
		"fast-xml-parser": "npm:fast-xml-parser@^5.9.3",
		"handlebars": "npm:handlebars@^4.7.9",
		"hash-wasm": "npm:hash-wasm@^4.12.0",
		"jose": "npm:jose@^6.1.0",
		"libphonenumber-js": "npm:libphonenumber-js@^1.11.0",
		"openid-client": "npm:openid-client@^6.8.1",
		"@js-temporal/polyfill": "npm:@js-temporal/polyfill@^0.5.1",
		"mailparser": "npm:mailparser@^3.9.11",
		"nodemailer": "npm:nodemailer@^9.0.1",
		"postgres": "npm:postgres@^3.4.9",
		"rrule-temporal": "npm:rrule-temporal@^1.5.3",
		"temporal-polyfill": "npm:temporal-polyfill@^1.0.1",
		"temporal-polyfill/global": "npm:temporal-polyfill@^1.0.1/global",
		"timezones-ical-library": "npm:timezones-ical-library@^2.2.1",
		"@electric-sql/pglite": "npm:@electric-sql/pglite@^0.5.3",
		"@std/testing/bdd": "jsr:@std/testing@^1.0.19/bdd",
		"@std/expect": "jsr:@std/expect@^1.0.19",
		"@std/fs": "jsr:@std/fs@^1.0.24"
	},
	"nodeModulesDir": "auto",
	"compilerOptions": {
		"lib": ["ESNext", "DOM", "DOM.Iterable", "deno.ns"],
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"verbatimModuleSyntax": true,
		"jsx": "react-jsx"
	},
	"allowScripts": [
		"npm:@parcel/watcher@2.5.6",
		"npm:esbuild@0.18.20",
		"npm:esbuild@0.25.12",
		"npm:esbuild@0.28.1"
	]
}
