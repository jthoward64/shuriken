{
	"name": "shuriken",
	"type": "module",
	"module": "src/index.ts",
	"private": true,
	"scripts": {
		"lint": "biome lint",
		"format": "biome format",
		"fix": "biome lint --fix; biome format --fix",
		"check": "tsc --noEmit",
		"start": "bun .",
		"serve": "bun --watch .",
		"test": "bun test",
		"test:unit": "bun test $(find . -name '*.unit.test.ts' -print)",
		"migrations:gen": "drizzle-kit generate",
		"migrations:run": "drizzle-kit migrate"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@effect/language-service": "^0.84.2",
		"@electric-sql/pglite": "^0.4.2",
		"@types/bun": "^1.3.11",
		"drizzle-kit": "beta",
		"typescript": "^6"
	},
	"imports": {
		"#src/*": "./src/*"
	},
	"dependencies": {
		"@effect/experimental": "^0.60.0",
		"@effect/opentelemetry": "^0.63.0",
		"@effect/platform": "^0.96.0",
		"@effect/platform-bun": "^0.89.0",
		"@opentelemetry/sdk-trace-base": "^2.6.1",
		"casbin": "^5.49.0",
		"drizzle-adapter": "^1.4.0",
		"drizzle-orm": "beta",
		"effect": "^3.21.0",
		"fast-xml-builder": "^1.1.4",
		"fast-xml-parser": "^5.5.9",
		"rrule-temporal": "^1.5.2",
		"temporal-polyfill": "^0.3.2"
	}
}
