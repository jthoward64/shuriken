{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"expand": "auto"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"recommended": true,
				"useNamingConvention": {
					"level": "warn",
					"options": {
						"strictCase": false,
						"requireAscii": true
					}
				},
				"noCommonJs": "error",
				"noEnum": "error",
				"noDescendingSpecificity": "warn",
				"noExportedImports": "error",
				"noMagicNumbers": {
					"level": "warn"
				},
				"noNamespace": "error",
				"noParameterAssign": "error",
				"noProcessEnv": "error",
				"noSubstr": "warn",
				"noYodaExpression": "warn",
				"useAsConstAssertion": "warn",
				"useAtIndex": "warn",
				"useBlockStatements": "warn",
				"useCollapsedElseIf": "warn",
				"useCollapsedIf": "warn",
				"useConsistentArrayType": {
					"level": "warn",
					"options": {
						"syntax": "generic"
					}
				},
				"useConsistentArrowReturn": "warn",
				"useConsistentBuiltinInstantiation": "warn",
				"useConsistentCurlyBraces": "warn",
				"useConsistentMemberAccessibility": "warn",
				"useConsistentObjectDefinitions": "warn",
				"useConsistentTypeDefinitions": "warn",
				"useForOf": "warn",
				"useDefaultParameterLast": "warn",
				"useFilenamingConvention": {
					"level": "warn",
					"options": {
						"strictCase": false,
						"requireAscii": true
					}
				},
				"useGroupedAccessorPairs": "warn",
				"useNumberNamespace": "warn",
				"useObjectSpread": "warn",
				"useReadonlyClassProperties": "warn"
			}
		},
		"domains": {
			"test": "recommended"
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		},
		"globals": ["Bun"]
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
