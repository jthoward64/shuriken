# Config is read via Effect's Config API (src/config.ts). camelCase keys
# there map to the SCREAMING_SNAKE_CASE env vars below.

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/shuriken

# Server
# PORT=3000
# HOST=::
# NODE_ENV=production
# NODE_ENV=development   # enables Effect DevTools

# Logging
# LOG_LEVEL=info

# Prometheus metrics (own listener, off the main port)
# METRICS_ENABLED=true
# METRICS_PORT=9464

# Auth mode — pick one. Precedence: AUTO_LOGIN > OIDC session > Basic auth.

# Option A: single-user / auto-login, all requests authed as this user
# AUTO_LOGIN=admin@example.com

# Option B: Basic auth (default on) — used by DAV clients
# BASIC_AUTH_ENABLED=true
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=          # random password generated + printed if unset
# ADMIN_SLUG=admin          # defaults to local part of ADMIN_EMAIL

# Option C: OIDC — web UI login only; DAV clients still need Basic auth
# (BASIC_AUTH_ENABLED=true, on by default) via app passwords generated at
# /ui/profile/app-passwords. Set BASIC_AUTH_ENABLED=false to lock the
# deployment to web-UI-only access (no DAV clients).
# OIDC_ENABLED=true
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=shuriken
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://shuriken.example.com/ui/auth/callback
# OIDC_SCOPES=openid profile email
# OIDC_AUTO_PROVISION=true
# SESSION_TTL_DAYS=7
# OIDC_GROUPS_CLAIM=groups   # both required together to enable role sync
# OIDC_ROLE_MAP={"shuriken-admins":"super_admin","staff":"admin"}

# Trusted proxies — gates X-Forwarded-* and the SMTP proxy headers below
# TRUSTED_PROXIES=*

# Share UI "pick a user" directory search — admin_only (default) | exact_email | open
# SHARING_USER_SEARCH_MODE=admin_only

# External account-settings link on the profile page (e.g. SSO portal)
# AUTH_SETTINGS_URL=https://sso.example.com/account?username={email}
# AUTH_SETTINGS_LABEL=Manage account

# Outbound mail (SMTP) — off by default
# MAIL_ENABLED=false

# Default relay, used when no per-user creds or profile match
# SMTP_FROM_ADDRESS=shuriken@example.com
# SMTP_FROM_NAME=Shuriken
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_SECURITY=starttls   # none | starttls | tls

# Encrypts per-user SMTP passwords stored in the DB; unset disables that source
# EMAIL_CREDS_KEY=

# Regex-scoped SMTP relay profiles, first pattern match wins
# SMTP_PROFILES_JSON=[{"pattern":"^.*@example\\.com$","host":"smtp.example.com","port":587,"username":"relay@example.com","password":"secret","security":"starttls"}]

# Per-request SMTP creds from a trusted reverse proxy (needs TRUSTED_PROXIES)
# SMTP_PROXY_USERNAME_HEADER=X-Smtp-Username
# SMTP_PROXY_PASSWORD_HEADER=X-Smtp-Password
# SMTP_PROXY_HOST_HEADER=X-Smtp-Host
# SMTP_PROXY_PORT_HEADER=X-Smtp-Port
# SMTP_PROXY_SECURITY_HEADER=X-Smtp-Security

# Incoming iMIP over LMTP, off by default
# LMTP_ENABLED=false
# LMTP_PORT=2400
# LMTP_HOST=127.0.0.1

# External calendar subscriptions (ICS feeds)
# EXTERNAL_CALENDAR_SCHEDULER_TICK_S=60
# EXTERNAL_CALENDAR_FETCH_CONCURRENCY=4
# EXTERNAL_CALENDAR_CLAIM_CAP=100   # max claims per shared feed URL

# Birthday reconciliation
# BIRTHDAY_SCHEDULER_TICK_S=600
# BIRTHDAY_CONCURRENCY=4

# Trash / soft-delete retention (0 disables trash entirely)
# TRASH_RETENTION_DAYS=30

# Embedding — chrome-less authenticated panes + public calendar widget, both off by default
# EMBED_PANES_ENABLED=false
# EMBED_CALENDAR_WIDGET_ENABLED=false

# Security response headers
# SECURITY_HEADERS_ENABLED=true
# CSP_ENABLED=true
# CSP_FRAME_ANCESTORS=https://intranet.example.com   # allowed to frame /ui/embed/* only
# X_CONTENT_TYPE_OPTIONS_ENABLED=true
# REFERRER_POLICY_ENABLED=true
# HSTS_ENABLED=true
# PERMISSIONS_POLICY_ENABLED=true
