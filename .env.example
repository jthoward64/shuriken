# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/shuriken

# Server (optional)
PORT=3000
HOST=::

# Auth mode: single-user | basic | proxy (optional, default: single-user)
AUTH_MODE=single-user

# Single-user mode: email of the user to treat as the authenticated principal
# If unset, the first user in the database is used
SINGLE_USER_EMAIL=admin@example.com

# Proxy auth: header injected by the reverse proxy with the authenticated username
# PROXY_HEADER=X-Remote-User

# Proxy auth: comma-separated trusted proxy IPs, or "*" to trust all
# TRUSTED_PROXIES=*

# Logging (optional)
# LOG_LEVEL=info
