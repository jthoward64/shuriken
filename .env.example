# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/shuriken

# Server (optional)
PORT=3000
HOST=::

# Auto-login / single-user mode (optional)
# When set, all requests are authenticated as this user without credential
# checks. Takes precedence over both proxy and basic auth.
# AUTO_LOGIN=admin@example.com

# Proxy auth (optional): set the header injected by the reverse proxy to
# enable proxy auth. Leave unset to disable.
# PROXY_HEADER=X-Remote-User

# Proxy auth: comma-separated trusted proxy IPs, or "*" to trust all.
# Only meaningful when PROXY_HEADER is set.
# TRUSTED_PROXIES=*

# Basic auth (enabled by default). Set to false to disable.
# BASIC_AUTH_ENABLED=true

# Admin user provisioning for basic auth (optional)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# ADMIN_SLUG=admin

# External calendar subscriptions (optional tunables)
# How often the background scheduler scans for due ICS feeds. Per-feed cadence
# is governed by each subscription's own sync_interval_s; this just bounds how
# soon a newly-due feed gets picked up.
# EXTERNAL_CALENDAR_SCHEDULER_TICK_S=60
# How many feeds the scheduler fetches in parallel per tick.
# EXTERNAL_CALENDAR_FETCH_CONCURRENCY=4
# Soft DoS guard — maximum number of distinct user-claims per shared feed URL.
# EXTERNAL_CALENDAR_CLAIM_CAP=100

# External account-settings URL surfaced on the user profile page.
# Useful behind an SSO portal (Authelia/Authentik/Keycloak/...) where the
# user changes their password and MFA settings on a different system.
# Supports {email}, {slug}, and {userId} placeholders, URL-encoded on render.
# AUTH_SETTINGS_URL=https://sso.example.com/account?username={email}
# AUTH_SETTINGS_LABEL=Manage account

# Logging (optional)
# LOG_LEVEL=info

# Enable Effect DevTools (connects to devtools server on localhost)
# NODE_ENV=development
