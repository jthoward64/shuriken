{{#if successMessage}}
  <div role="alert" class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
    {{successMessage}}
  </div>
{{/if}}
{{#if errorMessage}}
  <div role="alert" class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
    {{errorMessage}}
  </div>
{{/if}}
