{{#if aclPanel}}
<section id="acl-panel" class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
  <h2 class="text-base font-semibold text-gray-800">Access Control</h2>

  {{#if aclPanel.aces}}
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="text-left font-medium text-gray-700 pb-2">Principal</th>
          <th class="text-left font-medium text-gray-700 pb-2">Privilege</th>
          <th class="pb-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each aclPanel.aces}}
          <tr>
            <td class="py-2 text-gray-900">{{principalLabel}}</td>
            <td class="py-2 text-gray-600">{{privilegeLabel}}</td>
            <td class="py-2 text-right">
              {{#if protected}}
                <span class="text-xs text-gray-400" title="System-managed, cannot be removed">&#x1F512;</span>
              {{else}}
                <form
                  method="POST"
                  action="/ui/api/acl/{{../aclPanel.resourceType}}/{{../aclPanel.resourceId}}/revoke"
                  hx-post="/ui/api/acl/{{../aclPanel.resourceType}}/{{../aclPanel.resourceId}}/revoke"
                  hx-target="#acl-panel"
                  hx-swap="outerHTML"
                  class="inline"
                >
                  <input type="hidden" name="aceId" value="{{aceId}}">
                  <button
                    type="submit"
                    class="text-xs text-red-600 hover:text-red-800"
                    title="Revoke"
                  >
                    Revoke
                  </button>
                </form>
              {{/if}}
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p class="text-sm text-gray-500">No access entries yet.</p>
  {{/if}}

  <div class="border-t border-gray-100 pt-4">
    <p class="text-xs font-medium text-gray-600 mb-2">Grant access</p>
    <form
      method="POST"
      action="/ui/api/acl/{{aclPanel.resourceType}}/{{aclPanel.resourceId}}/grant"
      hx-post="/ui/api/acl/{{aclPanel.resourceType}}/{{aclPanel.resourceId}}/grant"
      hx-target="#acl-panel"
      hx-swap="outerHTML"
      class="flex items-end gap-2 flex-wrap"
    >
      <div>
        <label for="principalSlug" class="block text-xs text-gray-600 mb-1">Username or group slug</label>
        <input
          type="text"
          id="principalSlug"
          name="principalSlug"
          placeholder="e.g. alice"
          class="rounded border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
          required
        >
      </div>
      <div>
        <label for="privilege" class="block text-xs text-gray-600 mb-1">Privilege</label>
        <select
          id="privilege"
          name="privilege"
          class="rounded border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
          {{#each aclPanel.privilegeOptions}}
            <option value="{{value}}">{{label}}</option>
          {{/each}}
        </select>
      </div>
      <button
        type="submit"
        class="px-3 py-1.5 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700"
      >
        Grant
      </button>
    </form>
  </div>
</section>
{{/if}}
