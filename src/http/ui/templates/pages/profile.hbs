<div class="space-y-6 max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>

  {{> flash}}

  <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
    <h2 class="text-base font-semibold text-gray-800">Profile</h2>
    <form
      method="POST"
      action="/ui/api/users/{{principal.slug}}/update"
      hx-post="/ui/api/users/{{principal.slug}}/update"
      hx-target="body"
      hx-swap="outerHTML"
      class="space-y-4"
    >
      <div>
        <label for="displayName" class="block text-sm font-medium text-gray-700 mb-1">Display name</label>
        <input
          type="text"
          id="displayName"
          name="displayName"
          value="{{principal.displayName}}"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          value="{{user.email}}"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
      </div>
      {{#if canEditSlug}}
        <div>
          <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">Username (slug)</label>
          <input
            type="text"
            id="slug"
            name="slug"
            value="{{principal.slug}}"
            class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
          >
        </div>
      {{/if}}
      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        Save changes
      </button>
    </form>
  </section>

  {{#if showPasswordForm}}
    <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
      <h2 class="text-base font-semibold text-gray-800">Change password</h2>
      <form
        method="POST"
        action="/ui/api/users/{{principal.slug}}/set-password"
        hx-post="/ui/api/users/{{principal.slug}}/set-password"
        hx-target="body"
        hx-swap="outerHTML"
        class="space-y-4"
      >
        <div>
          <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">New password</label>
          <input
            type="password"
            id="newPassword"
            name="newPassword"
            autocomplete="new-password"
            class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
          >
        </div>
        <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
          Update password
        </button>
      </form>
    </section>
  {{/if}}
</div>
