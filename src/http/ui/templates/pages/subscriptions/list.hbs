<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
    <a href="/ui/subscriptions/new" class="inline-flex items-center px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
      Subscribe
    </a>
  </div>

  {{> flash}}

  {{#if subscriptions}}
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Calendar</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last sync</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {{#each subscriptions}}
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900">
                <span class="inline-block w-3 h-3 rounded-full align-middle mr-2" style="background-color: {{#if color}}{{color}}{{else}}#9ca3af{{/if}};"></span>
                {{displayName}}
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 font-mono break-all max-w-md">{{url}}</td>
              <td class="px-4 py-3 text-sm">
                {{#if lastSyncAt}}
                  <span class="{{#if (eq lastSyncStatus 'failure')}}text-red-600{{else}}text-gray-600{{/if}}">{{lastSyncStatus}}</span>
                  {{#if lastSyncError}}<div class="text-xs text-red-500 mt-1">{{lastSyncError}}</div>{{/if}}
                {{else}}
                  <span class="text-gray-400">never</span>
                {{/if}}
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <form method="POST" action="/ui/api/subscriptions/{{claimId}}/delete" hx-post="/ui/api/subscriptions/{{claimId}}/delete" hx-confirm="Unsubscribe and delete this calendar?" class="inline">
                  <button type="submit" class="text-red-600 hover:text-red-800">Unsubscribe</button>
                </form>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="text-gray-500 text-sm">You have no subscriptions yet. <a href="/ui/subscriptions/new" class="text-gray-700 underline">Subscribe to a calendar.</a></p>
  {{/if}}
</div>
