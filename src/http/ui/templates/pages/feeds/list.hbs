<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
    <a href="/ui/feeds/new" class="inline-flex items-center px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
      New feed
    </a>
  </div>

  {{> flash}}

  <p class="text-sm text-gray-600">
    Public read-only iCalendar feeds, each protected by a long random token. Share the feed URL with anyone who needs read access.
  </p>

  {{#if feeds}}
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Calendars</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {{#each feeds}}
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900">
                <a href="/ui/feeds/{{id}}" class="hover:text-gray-600">{{displayName}}</a>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600">{{calendarCount}}</td>
              <td class="px-4 py-3 text-sm">
                {{#if enabled}}<span class="text-green-600">enabled</span>{{else}}<span class="text-gray-400">disabled</span>{{/if}}
                {{#if expiresAt}}<span class="text-xs text-gray-400 ml-2">expires {{expiresAt}}</span>{{/if}}
              </td>
              <td class="px-4 py-3 text-right text-sm">
                <a href="{{feedUrl}}" class="text-gray-600 hover:text-gray-900 mr-3" title="Open feed">Open</a>
                <a href="/ui/feeds/{{id}}" class="text-gray-700 hover:text-gray-900">Edit</a>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="text-gray-500 text-sm">No feeds yet. <a href="/ui/feeds/new" class="text-gray-700 underline">Create one.</a></p>
  {{/if}}
</div>
