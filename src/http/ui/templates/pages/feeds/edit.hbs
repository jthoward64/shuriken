<div class="space-y-6 max-w-2xl">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a href="/ui/feeds" class="text-sm text-gray-500 hover:text-gray-700">Feeds</a>
      <span class="text-gray-400">/</span>
      <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
    </div>
    <form method="POST" action="/ui/api/feeds/{{feed.id}}/delete" hx-confirm="Delete this feed? The URL will stop working immediately.">
      <button type="submit" class="px-3 py-1.5 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700">
        Delete
      </button>
    </form>
  </div>

  {{> flash}}
  {{> form-error}}

  <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-3">
    <h2 class="text-base font-semibold text-gray-800">Feed URL</h2>
    <p class="text-sm font-mono break-all text-gray-700">{{feed.feedUrl}}</p>
    <form method="POST" action="/ui/api/feeds/{{feed.id}}/regenerate" hx-confirm="Regenerate the token? The current URL will stop working.">
      <button type="submit" class="text-xs text-gray-600 hover:text-gray-900 underline">
        Regenerate token
      </button>
    </form>
  </section>

  <section class="bg-white rounded-lg border border-gray-200 p-6">
    <form method="POST" action="/ui/api/feeds/{{feed.id}}/update" class="space-y-4">
      <div>
        <label for="displayName" class="block text-sm font-medium text-gray-700 mb-1">Display name</label>
        <input
          type="text"
          id="displayName"
          name="displayName"
          value="{{feed.displayName}}"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
      </div>

      <div>
        <label for="expiresAt" class="block text-sm font-medium text-gray-700 mb-1">Expires at (optional ISO instant)</label>
        <input
          type="text"
          id="expiresAt"
          name="expiresAt"
          value="{{feed.expiresAt}}"
          placeholder="2026-12-31T00:00:00Z"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox" id="enabled" name="enabled" {{#if feed.enabled}}checked{{/if}}>
        <label for="enabled" class="text-sm text-gray-700">Enabled</label>
      </div>

      <fieldset class="space-y-2">
        <legend class="block text-sm font-medium text-gray-700 mb-1">Calendars</legend>
        {{#each calendars}}
          <div class="flex items-center gap-3 py-1">
            <input type="checkbox" id="cal-{{id}}" name="calendar" value="{{id}}" {{#if linked}}checked{{/if}}>
            <label for="cal-{{id}}" class="text-sm flex-1">{{displayName}}</label>
            <select name="visibility:{{id}}" class="rounded border border-gray-300 px-2 py-1 text-xs">
              <option value="all" {{#if (eq visibility 'all')}}selected{{/if}}>Full details</option>
              <option value="limited" {{#if (eq visibility 'limited')}}selected{{/if}}>Title only</option>
              <option value="free_busy" {{#if (eq visibility 'free_busy')}}selected{{/if}}>Busy only</option>
            </select>
          </div>
        {{/each}}
      </fieldset>

      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        Save changes
      </button>
    </form>
  </section>
</div>
