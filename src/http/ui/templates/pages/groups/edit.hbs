<div class="space-y-6 max-w-2xl">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a href="/ui/groups" class="text-sm text-gray-500 hover:text-gray-700">Groups</a>
      <span class="text-gray-400">/</span>
      <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
    </div>
    {{#if canDelete}}
      <form
        method="POST"
        action="/ui/api/groups/{{principal.slug}}/delete"
        hx-post="/ui/api/groups/{{principal.slug}}/delete"
        hx-target="body"
        hx-swap="outerHTML"
        hx-confirm="Delete this group? This cannot be undone."
        class="inline"
      >
        <button type="submit" class="px-3 py-1.5 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700">
          Delete
        </button>
      </form>
    {{/if}}
  </div>

  {{> flash}}
  {{> form-error}}

  <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
    <h2 class="text-base font-semibold text-gray-800">Details</h2>
    <form
      method="POST"
      action="/ui/api/groups/{{principal.slug}}/update"
      hx-post="/ui/api/groups/{{principal.slug}}/update"
      hx-target="body"
      hx-swap="outerHTML"
      class="space-y-4"
    >
      <div>
        <label for="displayName" class="block text-sm font-medium text-gray-700 mb-1">Display name</label>
        <input
          type="text"
          id="displayName"
          name="displayName"
          value="{{principal.displayName}}"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
      </div>
      <div class="text-sm text-gray-600">
        <span class="font-medium text-gray-700">Slug:</span>
        <span class="font-mono ml-1">{{principal.slug}}</span>
      </div>
      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        Save changes
      </button>
    </form>
  </section>

  <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
    <h2 class="text-base font-semibold text-gray-800">Members</h2>
    {{#if members}}
      <ul class="divide-y divide-gray-100">
        {{#each members}}
          <li class="py-2 flex items-center justify-between text-sm">
            <span class="text-gray-900">
              {{principal.displayName}}{{#unless principal.displayName}}{{principal.slug}}{{/unless}}
            </span>
            <span class="text-gray-500 font-mono text-xs">{{principal.slug}}</span>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p class="text-gray-500 text-sm">No members yet.</p>
    {{/if}}
    <p class="text-xs text-gray-400">Manage membership from individual user edit pages.</p>
  </section>
</div>
