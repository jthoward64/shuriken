<div class="space-y-6 max-w-2xl">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      {{#if (eq ownerType "user")}}
        <a href="/ui/users" class="text-sm text-gray-500 hover:text-gray-700">Users</a>
        <span class="text-gray-400">/</span>
        <a href="/ui/users/{{ownerSlug}}" class="text-sm text-gray-500 hover:text-gray-700">{{ownerDisplayName}}</a>
      {{else}}
        <a href="/ui/groups" class="text-sm text-gray-500 hover:text-gray-700">Groups</a>
        <span class="text-gray-400">/</span>
        <a href="/ui/groups/{{ownerSlug}}" class="text-sm text-gray-500 hover:text-gray-700">{{ownerDisplayName}}</a>
      {{/if}}
      <span class="text-gray-400">/</span>
      <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
    </div>
    {{#if canDelete}}
      <form
        method="POST"
        action="/ui/api/collections/{{collection.id}}/delete"
        hx-post="/ui/api/collections/{{collection.id}}/delete"
        hx-target="body"
        hx-swap="outerHTML"
        hx-confirm="Delete this collection? This cannot be undone."
        class="inline"
      >
        <button type="submit" class="px-3 py-1.5 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700">
          Delete
        </button>
      </form>
    {{/if}}
  </div>

  {{> flash}}
  {{> form-error}}

  <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
    <h2 class="text-base font-semibold text-gray-800">Details</h2>
    <form
      method="POST"
      action="/ui/api/collections/{{collection.id}}/update"
      hx-post="/ui/api/collections/{{collection.id}}/update"
      hx-target="body"
      hx-swap="outerHTML"
      class="space-y-4"
    >
      <div>
        <label for="displayName" class="block text-sm font-medium text-gray-700 mb-1">Display name</label>
        <input
          type="text"
          id="displayName"
          name="displayName"
          value="{{collection.displayName}}"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >
      </div>
      <div>
        <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea
          id="description"
          name="description"
          rows="3"
          class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
        >{{collection.description}}</textarea>
      </div>
      {{#if isCalendar}}
        <div>
          <label for="timezoneTzid" class="block text-sm font-medium text-gray-700 mb-1">Timezone</label>
          <input
            type="text"
            id="timezoneTzid"
            name="timezoneTzid"
            value="{{collection.timezoneTzid}}"
            placeholder="e.g. America/New_York"
            class="w-full rounded border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500"
          >
        </div>
      {{/if}}
      <div class="text-sm text-gray-600">
        <span class="font-medium text-gray-700">Slug:</span>
        <span class="font-mono ml-1">{{collection.slug}}</span>
        <span class="text-xs text-gray-400 ml-2">(changing this breaks DAV client sync)</span>
      </div>
      <div class="text-sm text-gray-600">
        <span class="font-medium text-gray-700">Type:</span>
        <span class="ml-1">{{collection.collectionType}}</span>
      </div>
      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        Save changes
      </button>
    </form>
  </section>
</div>
