<div class="space-y-6 max-w-3xl">
  <div class="flex items-center gap-2">
    <a href="/ui/contacts?addressbook={{addressbookId}}" class="text-sm text-gray-500 hover:text-gray-700">Contacts</a>
    <span class="text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
  </div>

  {{> form-error}}

  <form method="POST" action="{{action}}" enctype="multipart/form-data" class="space-y-6 bg-white border border-gray-200 rounded-lg p-6">
    <input type="hidden" name="addressbookId" value="{{addressbookId}}" />

    <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Display name <span class="text-red-500">*</span></span>
        <input required type="text" name="fn" value="{{form.fn}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Family name</span>
        <input type="text" name="familyName" value="{{form.familyName}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Given name</span>
        <input type="text" name="givenName" value="{{form.givenName}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Nickname</span>
        <input type="text" name="nickname" value="{{form.nickname}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Kind</span>
        <select name="kind" class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm">
          <option value="" {{#if (eq form.kind '')}}selected{{/if}}>(unspecified)</option>
          <option value="individual" {{#if (eq form.kind 'individual')}}selected{{/if}}>Individual</option>
          <option value="group" {{#if (eq form.kind 'group')}}selected{{/if}}>Group</option>
          <option value="org" {{#if (eq form.kind 'org')}}selected{{/if}}>Organisation</option>
          <option value="location" {{#if (eq form.kind 'location')}}selected{{/if}}>Location</option>
        </select>
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Birthday</span>
        <input type="date" name="bday" value="{{form.bday}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Anniversary</span>
        <input type="date" name="anniversary" value="{{form.anniversary}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">Email</h2>
      {{#each form.emails}}
        <div class="flex gap-2 mb-2">
          <input type="email" name="emails[].value" value="{{value}}" placeholder="address@example.com"
                 class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="emails[].types" value="{{types}}" placeholder="home, work"
                 class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="emails[].label" value="{{label}}" placeholder="Label"
                 class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
        </div>
      {{/each}}
      <div class="flex gap-2 mb-2">
        <input type="email" name="emails[].value" value="" placeholder="address@example.com"
               class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="emails[].types" value="" placeholder="home, work"
               class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="emails[].label" value="" placeholder="Label"
               class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
      </div>
      <p class="text-xs text-gray-500">Add another by submitting; blank rows are dropped server-side.</p>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">Phone</h2>
      {{#each form.tels}}
        <div class="flex gap-2 mb-2">
          <input type="tel" name="tels[].value" value="{{value}}"
                 class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="tels[].types" value="{{types}}" placeholder="cell, voice"
                 class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="tels[].label" value="{{label}}" placeholder="Label"
                 class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
        </div>
      {{/each}}
      <div class="flex gap-2 mb-2">
        <input type="tel" name="tels[].value" value=""
               class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="tels[].types" value="" placeholder="cell, voice"
               class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="tels[].label" value="" placeholder="Label"
               class="w-32 rounded border border-gray-300 px-3 py-2 text-sm" />
      </div>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">URLs</h2>
      {{#each form.urls}}
        <input type="url" name="urls[]" value="{{this}}"
               class="block w-full rounded border border-gray-300 px-3 py-2 text-sm mb-2" />
      {{/each}}
      <input type="url" name="urls[]" value="" placeholder="https://example.com"
             class="block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">Addresses</h2>
      {{#each form.addresses}}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-3 p-3 border border-gray-200 rounded">
          <input type="text" name="addresses[].street" value="{{street}}" placeholder="Street"
                 class="md:col-span-2 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].extended" value="{{extended}}" placeholder="Suite / unit"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].poBox" value="{{poBox}}" placeholder="PO Box"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].locality" value="{{locality}}" placeholder="City"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].region" value="{{region}}" placeholder="State / region"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].postalCode" value="{{postalCode}}" placeholder="Postal code"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].country" value="{{country}}" placeholder="Country"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].types" value="{{types}}" placeholder="home, work, billing, delivery"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].label" value="{{label}}" placeholder="Label"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
        </div>
      {{/each}}
      <details class="text-sm">
        <summary class="cursor-pointer text-gray-700">Add address</summary>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mt-3 p-3 border border-gray-200 rounded">
          <input type="text" name="addresses[].street" value="" placeholder="Street"
                 class="md:col-span-2 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].extended" value="" placeholder="Suite / unit"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].poBox" value="" placeholder="PO Box"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].locality" value="" placeholder="City"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].region" value="" placeholder="State / region"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].postalCode" value="" placeholder="Postal code"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].country" value="" placeholder="Country"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].types" value="" placeholder="home, work, billing, delivery"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="addresses[].label" value="" placeholder="Label"
                 class="rounded border border-gray-300 px-3 py-2 text-sm" />
        </div>
      </details>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">Social profiles</h2>
      {{#each form.socialProfiles}}
        <div class="flex gap-2 mb-2">
          <input type="text" name="social[].service" value="{{service}}" placeholder="Service (Mastodon, Nextcloud…)"
                 class="w-48 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="social[].value" value="{{value}}" placeholder="URL or username"
                 class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
        </div>
      {{/each}}
      <div class="flex gap-2 mb-2">
        <input type="text" name="social[].service" value="" placeholder="Service (Mastodon, Nextcloud…)"
               class="w-48 rounded border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="social[].value" value="" placeholder="URL or username"
               class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
      </div>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">Instant messaging</h2>
      {{#each form.impps}}
        <div class="flex gap-2 mb-2">
          <input type="text" name="impp[].service" value="{{service}}" placeholder="Service (Skype, XMPP…)"
                 class="w-48 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="impp[].value" value="{{value}}" placeholder="handle or URI"
                 class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
        </div>
      {{/each}}
      <div class="flex gap-2 mb-2">
        <input type="text" name="impp[].service" value="" placeholder="Service (Skype, XMPP…)"
               class="w-48 rounded border border-gray-300 px-3 py-2 text-sm" />
        <input type="text" name="impp[].value" value="" placeholder="handle or URI"
               class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm" />
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Pronouns</span>
        <input type="text" name="pronouns" value="{{form.pronouns}}" placeholder="they/them"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Gender</span>
        <input type="text" name="gender" value="{{form.gender}}" placeholder="e.g. F, M, O…"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Grammatical gender</span>
        <select name="gramGender" class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm">
          <option value="" {{#if (eq form.gramGender '')}}selected{{/if}}>(unspecified)</option>
          <option value="animate" {{#if (eq form.gramGender 'animate')}}selected{{/if}}>animate</option>
          <option value="common" {{#if (eq form.gramGender 'common')}}selected{{/if}}>common</option>
          <option value="feminine" {{#if (eq form.gramGender 'feminine')}}selected{{/if}}>feminine</option>
          <option value="inanimate" {{#if (eq form.gramGender 'inanimate')}}selected{{/if}}>inanimate</option>
          <option value="masculine" {{#if (eq form.gramGender 'masculine')}}selected{{/if}}>masculine</option>
          <option value="neuter" {{#if (eq form.gramGender 'neuter')}}selected{{/if}}>neuter</option>
        </select>
      </label>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Organisation</span>
        <input type="text" name="org" value="{{form.org}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Title</span>
        <input type="text" name="title" value="{{form.title}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block md:col-span-2">
        <span class="block text-sm font-medium text-gray-700">Categories (comma-separated)</span>
        <input type="text" name="categoriesCsv" value="{{form.categoriesCsv}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block md:col-span-2">
        <span class="block text-sm font-medium text-gray-700">Note</span>
        <textarea name="note" rows="3"
                  class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm">{{form.note}}</textarea>
      </label>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-gray-700 mb-2">Photo</h2>
      {{#if form.photo}}
        <img src="{{form.photo}}" alt="Contact photo" class="w-24 h-24 object-cover rounded mb-2" />
      {{/if}}
      <label class="block text-sm">
        <span class="text-gray-700">Upload (max 512 KB):</span>
        <input type="file" name="photoFile" accept="image/*" class="ml-2" />
      </label>
      <label class="block text-sm mt-2">
        <span class="text-gray-700">…or paste a URL:</span>
        <input type="url" name="photo" value="{{form.photo}}"
               class="ml-2 rounded border border-gray-300 px-3 py-2 text-sm w-2/3" />
      </label>
    </section>

    <section>
      <details class="text-sm" {{#if form.otherProps}}open{{/if}}>
        <summary class="cursor-pointer text-sm font-semibold text-gray-700">
          Other fields ({{form.otherProps.length}})
        </summary>
        <p class="text-xs text-gray-500 mt-1 mb-2">
          Any other vCard property. Parameters go in the last box as
          <code>NAME=value;NAME=value</code>. Clear the name to remove a row.
        </p>
        {{#each form.otherProps}}
          <div class="grid grid-cols-1 md:grid-cols-4 gap-2 mb-2">
            <input type="text" name="other[].name" value="{{name}}" placeholder="PROPERTY"
                   class="rounded border border-gray-300 px-3 py-2 text-sm font-mono uppercase" />
            <input type="text" name="other[].value" value="{{value}}" placeholder="value"
                   class="md:col-span-2 rounded border border-gray-300 px-3 py-2 text-sm" />
            <input type="text" name="other[].params" value="{{params}}" placeholder="TYPE=work;PREF=1"
                   class="rounded border border-gray-300 px-3 py-2 text-sm font-mono" />
            <input type="hidden" name="other[].group" value="{{group}}" />
          </div>
        {{/each}}
        <div class="grid grid-cols-1 md:grid-cols-4 gap-2 mb-2">
          <input type="text" name="other[].name" value="" placeholder="PROPERTY"
                 class="rounded border border-gray-300 px-3 py-2 text-sm font-mono uppercase" />
          <input type="text" name="other[].value" value="" placeholder="value"
                 class="md:col-span-2 rounded border border-gray-300 px-3 py-2 text-sm" />
          <input type="text" name="other[].params" value="" placeholder="TYPE=work;PREF=1"
                 class="rounded border border-gray-300 px-3 py-2 text-sm font-mono" />
          <input type="hidden" name="other[].group" value="" />
        </div>
      </details>
    </section>

    <div class="flex flex-wrap gap-3 pt-2">
      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        {{#if (eq mode 'edit')}}Save changes{{else}}Create contact{{/if}}
      </button>
      <a href="/ui/contacts?addressbook={{addressbookId}}" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded hover:bg-gray-50">
        Cancel
      </a>
    </div>
  </form>

  {{#if (eq mode 'edit')}}
    <form method="POST" action="{{deleteAction}}"
          onsubmit="return confirm('Delete this contact?')"
          class="bg-white border border-red-200 rounded-lg p-6">
      <h2 class="text-sm font-semibold text-red-700 mb-2">Danger zone</h2>
      <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700">
        Delete contact
      </button>
    </form>
  {{/if}}
</div>
