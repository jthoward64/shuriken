<div class="space-y-4">
  <div class="flex items-center justify-between gap-4 flex-wrap">
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
    {{#if hasAddressbook}}
      <div class="flex items-center gap-2 flex-wrap">
        <a href="/ui/contacts/export.vcf?addressbook={{selectedId}}"
           class="inline-flex items-center px-3 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded hover:bg-gray-50">
          Export .vcf
        </a>
        <form
          method="POST"
          action="/ui/api/contacts/{{selectedId}}/import"
          enctype="multipart/form-data"
          hx-post="/ui/api/contacts/{{selectedId}}/import"
          hx-encoding="multipart/form-data"
          hx-target="#import-result"
          hx-swap="innerHTML"
          class="inline-flex items-center gap-1"
        >
          <label class="inline-flex items-center px-3 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded hover:bg-gray-50 cursor-pointer">
            Import .vcf
            <input type="file" name="file" accept=".vcf,text/vcard" class="hidden" onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()">
          </label>
          <select name="mode" class="rounded border border-gray-300 px-2 py-1.5 text-xs">
            <option value="error">Error on conflict</option>
            <option value="skip">Skip duplicates</option>
            <option value="merge">Replace duplicates</option>
          </select>
        </form>
        <a href="/ui/contacts/new?addressbook={{selectedId}}"
           class="inline-flex items-center px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
          New contact
        </a>
      </div>
    {{/if}}
  </div>

  {{> flash}}
  <div id="import-result"></div>

  <form method="GET" action="/ui/contacts" class="flex flex-wrap items-center gap-3 bg-white border border-gray-200 rounded-lg p-3">
    <label class="text-sm text-gray-700">
      Address book:
      <select name="addressbook" onchange="this.form.submit()"
              class="ml-1 rounded border border-gray-300 px-2 py-1 text-sm">
        {{#each addressbooks}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{displayName}}</option>
        {{/each}}
      </select>
    </label>
    <label class="text-sm text-gray-700 flex-1 min-w-[12rem]">
      Search:
      <input type="search" name="q" value="{{query}}" placeholder="Name…"
             class="ml-1 rounded border border-gray-300 px-2 py-1 text-sm w-full" />
    </label>
    <button type="submit" class="px-3 py-1.5 bg-gray-200 text-gray-800 text-sm rounded">Filter</button>
  </form>

  {{#if hasAddressbook}}
    {{#if contacts}}
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Phone</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {{#each contacts}}
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900">{{fn}}</td>
                <td class="px-4 py-3 text-sm text-gray-600">{{email}}</td>
                <td class="px-4 py-3 text-sm text-gray-600">{{tel}}</td>
                <td class="px-4 py-3 text-right text-sm">
                  <a href="/ui/contacts/{{instanceId}}" class="text-gray-600 hover:text-gray-900">Open</a>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <p class="text-gray-500 text-sm">No contacts here yet.</p>
    {{/if}}
  {{else}}
    <p class="text-gray-500 text-sm">No address book available. Create one from your profile.</p>
  {{/if}}
</div>
