<div class="space-y-6 max-w-2xl">
  <div class="flex items-center gap-2">
    <a href="/ui/shared" class="text-sm text-gray-500 hover:text-gray-700">Shared with me</a>
    <span class="text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
  </div>

  <section class="bg-white rounded-lg border border-gray-200 p-6 space-y-2">
    <p class="text-sm text-gray-600">
      Resource slug: <span class="font-mono">{{instance.slug}}</span>
    </p>
    <p class="text-sm text-gray-600">
      Parent calendar: <a href="/ui/collections/{{instance.collectionId}}" class="text-gray-700 underline">{{instance.collectionId}}</a>
    </p>
  </section>

  {{> acl-panel}}
</div>
