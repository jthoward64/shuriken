<div class="space-y-6 max-w-2xl">
  <div class="flex items-center gap-2">
    <a href="/ui/profile" class="text-sm text-gray-500 hover:text-gray-700">Profile</a>
    <span class="text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
  </div>

  <section class="bg-white rounded-lg border border-gray-200 p-4 text-sm text-gray-700 space-y-1">
    <p>App passwords let you connect calendar and contact apps (Thunderbird, iOS, DAVx⁵, …)
      without sharing your single-sign-on credentials. Each app password is a separate, revocable
      secret you enter in place of a password.</p>
    <p class="text-gray-500">Use your generated username together with the app password when your
      client asks for a username and password.</p>
  </section>

  {{#if generated}}
    <section class="bg-green-50 border border-green-300 rounded-lg p-6 space-y-3">
      <h2 class="text-sm font-semibold text-green-800">New app password created</h2>
      <p class="text-sm text-green-700">Copy these now — the password is shown only once and cannot be retrieved later.</p>
      <div class="space-y-2">
        <label class="block">
          <span class="block text-xs font-medium text-gray-600">Username</span>
          <input readonly value="{{generated.username}}"
                 class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono bg-white" />
        </label>
        <label class="block">
          <span class="block text-xs font-medium text-gray-600">Password</span>
          <input readonly value="{{generated.password}}"
                 class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono bg-white" />
        </label>
      </div>
    </section>
  {{/if}}

  <form method="POST" action="/ui/api/profile/app-passwords/create"
        class="space-y-4 bg-white rounded-lg border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900">Create an app password</h2>
    <label class="block">
      <span class="block text-sm font-medium text-gray-700">Label (optional)</span>
      <input type="text" name="label" maxlength="100" placeholder="e.g. iPhone, Thunderbird"
             class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
    </label>
    <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
      Generate
    </button>
  </form>

  <section class="bg-white rounded-lg border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Your app passwords</h2>
    {{#if appPasswords.length}}
      <ul class="divide-y divide-gray-100">
        {{#each appPasswords}}
          <li class="flex items-center justify-between py-3 gap-4">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">
                {{#if this.label}}{{this.label}}{{else}}<span class="text-gray-400">No label</span>{{/if}}
              </p>
              <p class="text-xs text-gray-500 font-mono truncate">{{this.username}}</p>
              <p class="text-xs text-gray-400">
                Created {{this.created}}{{#if this.lastUsed}} · Last used {{this.lastUsed}}{{else}} · Never used{{/if}}
              </p>
            </div>
            <form method="POST" action="/ui/api/profile/app-passwords/revoke"
                  onsubmit="return confirm('Revoke this app password? Any client using it will stop working.')">
              <input type="hidden" name="id" value="{{this.id}}" />
              <button type="submit" class="px-3 py-1.5 bg-red-600 text-white text-xs font-medium rounded hover:bg-red-700">
                Revoke
              </button>
            </form>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p class="text-sm text-gray-500">You don't have any app passwords yet.</p>
    {{/if}}
  </section>
</div>
