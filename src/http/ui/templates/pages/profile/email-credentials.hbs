<div class="space-y-6 max-w-2xl">
  <div class="flex items-center gap-2">
    <a href="/ui/profile" class="text-sm text-gray-500 hover:text-gray-700">Profile</a>
    <span class="text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
  </div>

  <section class="bg-white rounded-lg border border-gray-200 p-4 text-sm text-gray-700 space-y-1">
    <p><span class="font-medium">Status:</span>
      {{#if (eq activeKind 'user')}}
        Sending mail with your own SMTP credentials.
      {{else if (eq activeKind 'profile')}}
        Sending mail through a server-wide profile that matches your address.
      {{else if (eq activeKind 'default')}}
        Sending mail through the server's default relay; replies will go to your address.
      {{else}}
        Mail is currently disabled on this server.
      {{/if}}
    </p>
    {{#if activeFromAddress}}
      <p><span class="font-medium">Outgoing From:</span> <span class="font-mono">{{activeFromAddress}}</span></p>
    {{/if}}
    {{#unless mailEnabled}}
      <p class="text-gray-500">Set <span class="font-mono">MAIL_ENABLED=true</span> in the server config to enable outbound mail.</p>
    {{/unless}}
    {{#unless credsKeyConfigured}}
      <p class="text-gray-500">Note: <span class="font-mono">EMAIL_CREDS_KEY</span> is not set, so per-user credentials cannot be saved.</p>
    {{/unless}}
  </section>

  <form method="POST" action="/ui/api/profile/email-credentials/save" class="space-y-4 bg-white rounded-lg border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900">Override with your own SMTP server</h2>
    <p class="text-sm text-gray-600">If your provider gives you SMTP credentials, enter them here so mail goes out as you.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">From address <span class="text-red-500">*</span></span>
        <input required type="email" name="fromAddress"
               value="{{#if existing}}{{existing.fromAddress}}{{else}}{{userEmail}}{{/if}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">From display name</span>
        <input type="text" name="fromName"
               value="{{#if existing}}{{existing.fromName}}{{/if}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">SMTP host <span class="text-red-500">*</span></span>
        <input required type="text" name="host"
               value="{{#if existing}}{{existing.host}}{{/if}}"
               placeholder="smtp.example.com"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Port <span class="text-red-500">*</span></span>
        <input required type="number" min="1" max="65535" name="port"
               value="{{#if existing}}{{existing.port}}{{else}}587{{/if}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Username <span class="text-red-500">*</span></span>
        <input required type="text" name="username"
               value="{{#if existing}}{{existing.username}}{{/if}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Password <span class="text-red-500">*</span></span>
        <input required type="password" name="password" autocomplete="new-password"
               placeholder="{{#if existing}}Leave blank to keep current{{/if}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block md:col-span-2">
        <span class="block text-sm font-medium text-gray-700">Connection security</span>
        <select name="security" class="mt-1 rounded border border-gray-300 px-2 py-1 text-sm">
          {{#with existing}}
            <option value="none" {{#if (eq security 'none')}}selected{{/if}}>None</option>
            <option value="starttls" {{#if (eq security 'starttls')}}selected{{/if}}>STARTTLS</option>
            <option value="tls" {{#if (eq security 'tls')}}selected{{/if}}>TLS / SSL</option>
          {{else}}
            <option value="none">None</option>
            <option value="starttls" selected>STARTTLS</option>
            <option value="tls">TLS / SSL</option>
          {{/with}}
        </select>
      </label>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        Save credentials
      </button>
      <a href="/ui/profile" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded hover:bg-gray-50">
        Cancel
      </a>
    </div>
  </form>

  {{#if existing}}
    <form method="POST" action="/ui/api/profile/email-credentials/clear"
          onsubmit="return confirm('Remove your saved SMTP credentials? You will fall back to the server profile or default.')"
          class="bg-white border border-red-200 rounded-lg p-6">
      <h2 class="text-sm font-semibold text-red-700 mb-2">Remove credentials</h2>
      <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700">
        Clear credentials
      </button>
    </form>
  {{/if}}
</div>
