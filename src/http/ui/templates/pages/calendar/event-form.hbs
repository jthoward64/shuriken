<div class="space-y-6 max-w-2xl">
  <div class="flex items-center gap-2">
    <a href="{{backHref}}" class="text-sm text-gray-500 hover:text-gray-700">Calendar</a>
    <span class="text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>
  </div>

  <form method="POST" action="{{action}}" class="space-y-5 bg-white border border-gray-200 rounded-lg p-6">
    <label class="block">
      <span class="block text-sm font-medium text-gray-700">Title <span class="text-red-500">*</span></span>
      <input required type="text" name="summary" value="{{form.summary}}"
             class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
    </label>

    <div class="flex items-center gap-2">
      <input id="allDay" type="checkbox" name="allDay" {{#if form.allDay}}checked{{/if}}
             class="rounded border-gray-300" />
      <label for="allDay" class="text-sm text-gray-700">All-day event</label>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">Start <span class="text-red-500">*</span></span>
        <input required type="text" name="start" value="{{form.start}}"
               placeholder="YYYY-MM-DDTHH:mm or YYYY-MM-DD"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700">End</span>
        <input type="text" name="end" value="{{form.end}}"
               placeholder="YYYY-MM-DDTHH:mm or YYYY-MM-DD"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
    </div>

    <label class="block">
      <span class="block text-sm font-medium text-gray-700">Location</span>
      <input type="text" name="location" value="{{form.location}}"
             class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
    </label>

    <label class="block">
      <span class="block text-sm font-medium text-gray-700">Description</span>
      <textarea name="description" rows="3"
                class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm">{{form.description}}</textarea>
    </label>

    <label class="block">
      <span class="block text-sm font-medium text-gray-700">Categories (comma-separated)</span>
      <input type="text" name="categoriesCsv" value="{{form.categoriesCsv}}"
             class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
    </label>

    <fieldset class="border border-gray-200 rounded p-4 space-y-3">
      <legend class="text-sm font-medium text-gray-700 px-1">Attendees</legend>
      <label class="block">
        <span class="block text-xs text-gray-600">Email addresses (one per line or comma-separated)</span>
        <textarea name="attendeesCsv" rows="3"
                  placeholder="alice@example.com&#10;bob@example.org"
                  class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm">{{#each form.attendees}}{{this}}{{#unless @last}}
{{/unless}}{{/each}}</textarea>
      </label>
      <label class="block">
        <span class="block text-xs text-gray-600">Organizer (optional override)</span>
        <input type="email" name="organizer" value="{{form.organizer}}"
               class="mt-1 block w-full rounded border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <p class="text-xs text-gray-500">Non-local attendees receive an iMIP invite when the event is saved or cancelled.</p>
    </fieldset>

    <fieldset class="border border-gray-200 rounded p-4 space-y-3">
      <legend class="text-sm font-medium text-gray-700 px-1">Repeat</legend>
      <label class="block">
        <span class="block text-xs text-gray-600">Frequency</span>
        <select name="recurrenceFreq" class="mt-1 rounded border border-gray-300 px-2 py-1 text-sm">
          <option value="" {{#if (eq form.recurrenceFreq '')}}selected{{/if}}>None</option>
          <option value="DAILY" {{#if (eq form.recurrenceFreq 'DAILY')}}selected{{/if}}>Daily</option>
          <option value="WEEKLY" {{#if (eq form.recurrenceFreq 'WEEKLY')}}selected{{/if}}>Weekly</option>
          <option value="MONTHLY" {{#if (eq form.recurrenceFreq 'MONTHLY')}}selected{{/if}}>Monthly</option>
          <option value="YEARLY" {{#if (eq form.recurrenceFreq 'YEARLY')}}selected{{/if}}>Yearly</option>
        </select>
      </label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <label class="block">
          <span class="block text-xs text-gray-600">Occurrence count</span>
          <input type="number" min="1" name="recurrenceCount" value="{{form.recurrenceCount}}"
                 class="mt-1 block w-full rounded border border-gray-300 px-2 py-1 text-sm" />
        </label>
        <label class="block">
          <span class="block text-xs text-gray-600">Or until</span>
          <input type="date" name="recurrenceUntil" value="{{form.recurrenceUntil}}"
                 class="mt-1 block w-full rounded border border-gray-300 px-2 py-1 text-sm" />
        </label>
      </div>
      <p class="text-xs text-gray-500">Count wins over Until when both are set.</p>
    </fieldset>

    <div class="flex flex-wrap gap-3 pt-2">
      <button type="submit" class="px-4 py-2 bg-gray-800 text-white text-sm font-medium rounded hover:bg-gray-700">
        {{#if (eq mode 'edit')}}Save changes{{else}}Create event{{/if}}
      </button>
      <a href="{{backHref}}" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded hover:bg-gray-50">
        Cancel
      </a>
    </div>
  </form>

  {{#if (eq mode 'edit')}}
    <form method="POST" action="{{deleteAction}}"
          onsubmit="return confirm('Delete this event?')"
          class="bg-white border border-red-200 rounded-lg p-6">
      <h2 class="text-sm font-semibold text-red-700 mb-2">Danger zone</h2>
      <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700">
        Delete event
      </button>
    </form>
  {{/if}}
</div>
