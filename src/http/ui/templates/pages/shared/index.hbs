<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900">{{pageTitle}}</h1>

  <section class="space-y-3">
    <h2 class="text-lg font-semibold text-gray-800">Calendars &amp; address books</h2>
    {{#if sharedCollections}}
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Shared by</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {{#each sharedCollections}}
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900">{{displayName}}</td>
                <td class="px-4 py-3 text-sm text-gray-600">{{collectionType}}</td>
                <td class="px-4 py-3 text-sm text-gray-600 font-mono">{{ownerSlug}}</td>
                <td class="px-4 py-3 text-right text-sm">
                  <a href="/ui/collections/{{id}}" class="text-gray-600 hover:text-gray-900">Open</a>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <p class="text-gray-500 text-sm">Nothing shared with you yet.</p>
    {{/if}}
  </section>

  <section class="space-y-3">
    <h2 class="text-lg font-semibold text-gray-800">Individual events</h2>
    {{#if sharedInstances}}
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">From calendar</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            {{#each sharedInstances}}
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900 font-mono">{{slug}}</td>
                <td class="px-4 py-3 text-sm text-gray-600">{{collectionDisplay}}</td>
                <td class="px-4 py-3 text-right text-sm">
                  <a href="/ui/instances/{{id}}/acl" class="text-gray-600 hover:text-gray-900">View access</a>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <p class="text-gray-500 text-sm">No events shared individually.</p>
    {{/if}}
  </section>
</div>
